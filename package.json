{
  "name": "kaisalaga",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "trustedDependencies": [
    "inngest-cli",
    "protobufjs",
    "unrs-resolver"
  ],
  "scripts": {
    "dev": "NODE_OPTIONS='--no-deprecation' next dev",
    "inngest:dev": "inngest-cli dev -u http://localhost:3000/api/inngest",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:check": "drizzle-kit check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:pull": "drizzle-kit pull --config=drizzle.pull.config.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:smoke:backend": "bun --env-file=.env.local scripts/smoke-backend.mjs",
    "vercel:env": "bun scripts/push-vercel-env.mjs",
    "vercel:sync-urls": "bun scripts/sync-vercel-production-urls.mjs",
    "doctor": "npx react-doctor@latest",
    "render:illustrations": "cd tools/remotion && bun install && bun run render"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@clerk/nextjs": "^7.5.1",
    "@google/genai": "^2.8.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "inngest": "^4.5.1",
    "lucide-react": "^1.18.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "openai": "^6.42.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-qr-code": "^2.2.0",
    "recharts": "3.8.0",
    "resend": "^6.12.4",
    "sarvamai": "^1.1.7",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "inngest-cli": "^1.27.0",
    "jsdom": "^29.1.1",
    "postgres": "^3.4.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
